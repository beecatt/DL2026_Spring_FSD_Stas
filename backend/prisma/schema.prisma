generator client {
  provider = "prisma-client-js"
   binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QrCode {
  id          String   @id @default(cuid())
  content     String
  size        Int
  foreground  String
  background  String
  centerImage String?
  createdAt   DateTime @default(now())
}